#!/usr/bin/env bash
#PBS -q shortCPUQ
#PBS -l walltime=00:15:00
#PBS -l place=pack:excl
#PBS -j oe

set -euo pipefail

: "${N_THREADS:?Submit with qsub -v N_THREADS=<threads>}"

cd "${PBS_O_WORKDIR:?PBS_O_WORKDIR is not set}"
module load OpenMPI/4.1.6-GCC-13.2.0

# Weak scaling on the dimension axis: nd grows with the thread count, so each
# thread keeps a constant slice of dimensions. Few sharks, no rotation.
dims=$((100000 * N_THREADS))
output_dir="benchmarks/raw/weak_scaling_dim"
output_file="${output_dir}/weak_scaling_openmp_dim.txt"

mkdir -p "${output_dir}"

export OMP_NUM_THREADS="${N_THREADS}"
export OMP_PLACES=cores
export OMP_PROC_BIND=close
export OMP_DYNAMIC=false

result=$(
  ./sso_openmp_dim \
    -p 5 \
    -d "${dims}" \
    -k 20 \
    -m 0 \
    -t "${N_THREADS}" |
    sed -n '/threads=.*Total OpenMP time:/p'
)

if [[ -z "${result}" ]]; then
  echo "Could not extract OpenMP execution time" >&2
  exit 1
fi

(
  flock -x 9
  printf '%s\n' "${result}" >> "${output_file}"
) 9>"${output_file}.lock"
